{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asui.dev/schemas/capability_service.schema.json",
  "title": "UAS Capability Service Registry",
  "description": "企业业务能力服务化（cs.*）注册契约。Agent 仅通过语义 operation 调用，禁止暴露下游系统 URL。",
  "type": "object",
  "required": ["version", "registry_id", "services"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "registry_id": {
      "type": "string",
      "description": "注册表实例标识，如 edh-platform-default"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "defaults": {
      "type": "object",
      "properties": {
        "audit_required": { "type": "boolean", "default": true },
        "retry_max": { "type": "integer", "minimum": 0, "maximum": 5 },
        "timeout_ms": { "type": "integer", "minimum": 1000 }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/capabilityService" }
    }
  },
  "definitions": {
    "capabilityServiceId": {
      "type": "string",
      "pattern": "^cs\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)?$",
      "description": "语义服务 ID，如 cs.customer、cs.lead"
    },
    "operationName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "approvalLevel": {
      "type": "string",
      "enum": ["L1", "L2", "L3"]
    },
    "gateId": {
      "type": "string",
      "enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7"]
    },
    "capabilityOperation": {
      "type": "object",
      "required": [
        "name",
        "description",
        "approval_level",
        "audit_required",
        "gates"
      ],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/definitions/operationName" },
        "description": { "type": "string", "minLength": 1 },
        "input": {
          "type": "object",
          "description": "JSON Schema 内联或 $ref 到 components",
          "properties": {
            "type": { "const": "object" },
            "required": { "type": "array", "items": { "type": "string" } },
            "properties": { "type": "object" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "type": { "const": "object" },
            "required": { "type": "array", "items": { "type": "string" } },
            "properties": { "type": "object" }
          }
        },
        "approval_level": { "$ref": "#/definitions/approvalLevel" },
        "audit_required": { "type": "boolean" },
        "gates": {
          "type": "array",
          "items": { "$ref": "#/definitions/gateId" },
          "minItems": 1
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^event\\.[a-z0-9_.]+$"
          }
        },
        "idempotent": { "type": "boolean", "default": false },
        "agent_visible": {
          "type": "boolean",
          "default": true,
          "description": "是否暴露给 LLM 工具列表；false 时仅平台内部调用"
        }
      }
    },
    "capabilityService": {
      "type": "object",
      "required": ["id", "domain", "description", "source_system", "operations"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/capabilityServiceId" },
        "domain": {
          "type": "string",
          "description": "业务域：customer、lead、ticket、approval、notify、process 等"
        },
        "description": { "type": "string" },
        "source_system": {
          "type": "string",
          "enum": ["crm", "bpm", "oa", "finance", "itsm", "erp", "mock"]
        },
        "connector_id": {
          "type": "string",
          "description": "S-Grid 连接器实例，如 connector.crm.sandbox"
        },
        "uas_layer": {
          "type": "string",
          "enum": ["S"],
          "default": "S",
          "description": "对齐 UAS 八元组 S 层"
        },
        "enabled": { "type": "boolean", "default": true },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/capabilityOperation" }
        }
      }
    }
  }
}
