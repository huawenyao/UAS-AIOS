{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asui.dev/schemas/evaluation_criteria.schema.json",
  "title": "UAS Sub App 评价标准",
  "description": "业务、产品、技术、运行效果四维打分，驱动自主进化",
  "type": "object",
  "required": ["version", "dimensions"],
  "properties": {
    "version": { "type": "string" },
    "evolution_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 70,
      "description": "总分低于此阈值时触发进化建议"
    },
    "dimension_weights": {
      "type": "object",
      "description": "各维度权重，默认各0.25",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "dimensions": {
      "type": "object",
      "required": ["business", "product", "technology", "operational"],
      "properties": {
        "business": { "$ref": "#/$defs/Dimension" },
        "product": { "$ref": "#/$defs/Dimension" },
        "technology": { "$ref": "#/$defs/Dimension" },
        "operational": { "$ref": "#/$defs/Dimension" }
      }
    }
  },
  "$defs": {
    "Dimension": {
      "type": "object",
      "required": ["name", "items"],
      "properties": {
        "name": { "type": "string" },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "max_score"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "max_score": { "type": "number", "minimum": 0 },
              "check_type": { "type": "string", "enum": ["payload", "config", "file", "run_state"] },
              "check_path": { "type": "string" },
              "suggestion_template": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
