{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asui.dev/schemas/world_model_state.schema.json",
  "title": "UAS World Model State",
  "description": "世界模型运行时状态：状态空间、状态转移、执行上下文",
  "type": "object",
  "required": ["instance_id", "current_state", "context", "history"],
  "properties": {
    "instance_id": {
      "type": "string",
      "description": "世界模型实例ID"
    },
    "version": {
      "type": "string"
    },
    "current_state": {
      "$ref": "#/$defs/RuntimeState"
    },
    "context": {
      "$ref": "#/$defs/RuntimeContext"
    },
    "laws_state": {
      "$ref": "#/$defs/LawsState"
    },
    "reducer_state": {
      "$ref": "#/$defs/ReducerState"
    },
    "intent_guard_state": {
      "$ref": "#/$defs/IntentGuardState"
    },
    "evolution_state": {
      "$ref": "#/$defs/EvolutionState"
    },
    "history": {
      "$ref": "#/$defs/StateHistory"
    }
  },
  "$defs": {
    "RuntimeState": {
      "type": "object",
      "required": ["state_id", "state_name", "timestamp"],
      "properties": {
        "state_id": {
          "type": "string",
          "description": "状态唯一标识"
        },
        "state_name": {
          "type": "string",
          "enum": [
            "idle",
            "understanding",
            "mapping",
            "reducing",
            "reasoning",
            "validating",
            "executing",
            "monitoring",
            "evolving",
            "complete",
            "error",
            "blocked"
          ],
          "description": "状态名称"
        },
        "parent_state": {
          "type": "string",
          "description": "父状态（用于嵌套）"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "RuntimeContext": {
      "type": "object",
      "description": "运行时上下文",
      "properties": {
        "intent": {
          "$ref": "#/$defs/IntentContext"
        },
        "scenario": {
          "$ref": "#/$defs/ScenarioContext"
        },
        "constraints": {
          "$ref": "#/$defs/ConstraintContext"
        },
        "environment": {
          "$ref": "#/$defs/EnvironmentContext"
        }
      }
    },
    "IntentContext": {
      "type": "object",
      "description": "意图上下文",
      "properties": {
        "raw_input": {
          "type": "string"
        },
        "normalized": {
          "type": "string"
        },
        "vector": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stakeholders": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ScenarioContext": {
      "type": "object",
      "description": "场景上下文",
      "properties": {
        "type": {
          "type": "string"
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "attributes": {
                "type": "object"
              }
            }
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              },
              "target": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        },
        "initial_conditions": {
          "type": "object"
        },
        "expected_outcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ConstraintContext": {
      "type": "object",
      "description": "约束上下文",
      "properties": {
        "hard_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "soft_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resource_limits": {
          "type": "object",
          "properties": {
            "max_time_ms": {
              "type": "integer"
            },
            "max_iterations": {
              "type": "integer"
            },
            "max_cost": {
              "type": "number"
            }
          }
        }
      }
    },
    "EnvironmentContext": {
      "type": "object",
      "description": "环境上下文",
      "properties": {
        "system_state": {
          "type": "object"
        },
        "available_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "external_feeds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "LawsState": {
      "type": "object",
      "description": "法则库状态",
      "properties": {
        "activated_laws": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "law_confidences": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "conflict_detection": {
          "$ref": "#/$defs/ConflictDetection"
        }
      }
    },
    "ConflictDetection": {
      "type": "object",
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "law_a": {
                "type": "string"
              },
              "law_b": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "resolution": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "ReducerState": {
      "type": "object",
      "description": "降维引擎状态",
      "properties": {
        "high_dim_input": {
          "type": "object"
        },
        "low_dim_representation": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "dimension_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "abstraction_level": {
          "type": "number"
        },
        "compression_ratio": {
          "type": "number"
        }
      }
    },
    "IntentGuardState": {
      "type": "object",
      "description": "意图守恒状态",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "checks_performed": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "check_name": {
                "type": "string"
              },
              "passed": {
                "type": "boolean"
              },
              "score": {
                "type": "number"
              },
              "details": {
                "type": "string"
              }
            }
          }
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "severity": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "action_taken": {
                "type": "string"
              }
            }
          }
        },
        "overall_alignment": {
          "type": "number"
        }
      }
    },
    "EvolutionState": {
      "type": "object",
      "description": "演化状态",
      "properties": {
        "drift_detected": {
          "type": "boolean"
        },
        "drift_metrics": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "adaptation_count": {
          "type": "integer"
        },
        "last_adaptation": {
          "type": "string",
          "format": "date-time"
        },
        "adaptations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "trigger": {
                "type": "string"
              },
              "changes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "result": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "StateHistory": {
      "type": "object",
      "description": "状态历史",
      "properties": {
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from_state": {
                "type": "string"
              },
              "to_state": {
                "type": "string"
              },
              "event": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "duration_ms": {
                "type": "integer"
              },
              "context_snapshot": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  }
}
