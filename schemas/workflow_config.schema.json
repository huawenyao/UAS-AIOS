{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asui.dev/schemas/workflow_config.schema.json",
  "title": "ASUI Workflow Config",
  "description": "ASUI 知识驱动工作流配置规范，定义业务步骤、依赖关系与执行语义",
  "type": "object",
  "required": ["version", "steps"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
      "description": "工作流版本号，遵循语义化版本"
    },
    "name": {
      "type": "string",
      "description": "工作流名称"
    },
    "description": {
      "type": "string",
      "description": "工作流描述"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "工作流步骤定义",
      "items": {
        "$ref": "#/$defs/Step"
      }
    },
    "global_config": {
      "type": "object",
      "description": "全局配置，可被步骤引用",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Step": {
      "type": "object",
      "required": ["id", "name", "type"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "步骤唯一标识"
        },
        "name": {
          "type": "string",
          "description": "步骤显示名称"
        },
        "type": {
          "type": "string",
          "enum": ["script", "llm", "conditional", "parallel"],
          "description": "步骤类型：script=脚本执行, llm=LLM调用, conditional=条件分支, parallel=并行执行"
        },
        "description": {
          "type": "string",
          "description": "步骤说明"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "依赖的步骤ID列表，执行顺序由依赖决定"
        },
        "script": {
          "type": "string",
          "description": "type=script 时，要执行的脚本路径或命令"
        },
        "prompt_template": {
          "type": "string",
          "description": "type=llm 时，Prompt 模板，支持 {{variable}} 占位符"
        },
        "output_schema": {
          "type": "object",
          "description": "type=llm 时，期望输出的 JSON Schema，用于结构化解析"
        },
        "model": {
          "type": "string",
          "description": "type=llm 时，指定使用的模型"
        },
        "condition": {
          "type": "object",
          "description": "type=conditional 时，条件表达式",
          "properties": {
            "expression": { "type": "string" },
            "then_step": { "type": "string" },
            "else_step": { "type": "string" }
          }
        },
        "parallel_steps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "type=parallel 时，可并行执行的步骤ID列表"
        },
        "retry": {
          "type": "object",
          "description": "重试配置",
          "properties": {
            "max_attempts": { "type": "integer", "minimum": 1 },
            "delay_ms": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
