{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asui.dev/schemas/consent_record.schema.json",
  "title": "UAS Consent Record",
  "description": "主体对特定目的和数据范围作出的可审计、可撤回授权记录。",
  "type": "object",
  "required": [
    "consent_id",
    "subject_id",
    "controller_id",
    "purpose",
    "scopes",
    "status",
    "recorded_at"
  ],
  "additionalProperties": false,
  "properties": {
    "consent_id": {
      "type": "string",
      "pattern": "^consent-[a-zA-Z0-9._:-]+$"
    },
    "subject_id": {
      "type": "string",
      "minLength": 1,
      "description": "数据主体或参与者标识。"
    },
    "controller_id": {
      "type": "string",
      "minLength": 1,
      "description": "对处理目的负责的用户、应用或组织标识。"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
      }
    },
    "status": {
      "type": "string",
      "enum": ["requested", "granted", "denied", "revoked", "expired"]
    },
    "legal_basis": {
      "type": "string"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "effective_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "type": "object",
      "required": ["channel"],
      "additionalProperties": false,
      "properties": {
        "channel": { "type": "string", "minLength": 1 },
        "actor_id": { "type": "string" },
        "evidence_ref": { "type": "string" },
        "policy_version": { "type": "string" }
      }
    },
    "constraints": {
      "type": "object",
      "description": "地域、保留期限、接收方等机器可读限制。"
    },
    "supersedes_consent_id": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "revoked" } }
      },
      "then": {
        "required": ["revoked_at"]
      }
    }
  ]
}
