        {
          "id": "oa_notify",
          "system": "OA/IM 通知",
          "mode": "出站",
          "capability": "cs.notify.send_im",
          "required": false
        }
      ],
      "playbook_id": "playbook.cs_complaint_v1",
      "agent_id": "agent.cs_specialist",
      "demo_entry": "demoCsEscalation",
      "poc_duration_days": 30,
      "acceptance_criteria": [
        "Intent 升级成功率 ≥99%",
        "Playbook 三步 cs.* 全链路 audit_id 可追溯",
