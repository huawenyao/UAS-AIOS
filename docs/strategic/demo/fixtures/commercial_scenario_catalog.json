      "playbook_id": "playbook.sales_ltc_quote_v1",
      "agent_id": "agent.sales_advisor",
      "demo_entry": "demoLtcPlaybook",
      "poc_duration_days": 45,
      "acceptance_criteria": [
        "qualify → process → approval 三步可逐步执行",
        "超折扣阈值自动进入 approval_pending",
