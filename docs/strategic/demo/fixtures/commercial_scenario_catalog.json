      "label": "连系统",
      "desc": "Day-1 集成清单勾选"
    },
    {
      "step_id": "pilot",
      "label": "跑试点",
      "desc": "Playbook + Task Panel 真链路"
    },
    {
      "step_id": "accept",
      "label": "验收扩面",
      "desc": "审计报告 + 扩面路线图"
    }
  ],
  "kits": [
