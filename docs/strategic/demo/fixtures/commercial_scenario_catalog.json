      "value_promises": [
        {
          "metric": "首次响应时长",
          "baseline": "4.2h",
          "target": "≤1h",
          "unit": "小时"
        },
        {
          "metric": "SLA 达标率",
          "baseline": "82%",
          "target": "≥95%",
          "unit": "%"
        },
        {
          "metric": "审计可追溯率",
          "baseline": "40%",
          "target": "100%",
          "unit": "%"
        }
      ],
      "roi_model": {
        "ticket_volume_monthly": 1200,
        "minutes_saved_per_ticket": 18,
        "labor_cost_per_hour": 85,
        "sla_penalty_avoided_monthly": 15000
