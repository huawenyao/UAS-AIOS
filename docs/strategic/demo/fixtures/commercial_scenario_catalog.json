        {
          "id": "bpm_quote",
          "system": "BPM 报价审批",
          "mode": "读写",
          "capability": "cs.process.start",
          "required": true
        },
        {
          "id": "oa_approval",
          "system": "OA 折扣审批",
          "mode": "读写",
          "capability": "cs.approval.submit",
          "required": true
        },
        {
          "id": "bi_margin",
          "system": "BI Margin 只读",
          "mode": "只读",
          "capability": "指标接入",
          "required": false
