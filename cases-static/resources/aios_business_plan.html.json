  "contents": [
    {
      "uri": "file://aios_business_plan.html",
      "mimeType": "text/html",
      "text": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>UAS-AIOS 商业计划书 · AI 操作系统 — 投资概要</title>\n<meta name=\"description\" content=\"UAS-AIOS：让每个人驾驭所有专业系统的全部智能。AI 操作系统商业计划书，面向投资者。\">\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\n:root{\n  --bg:#f8fafc;--card:#fff;--border:#e2e8f0;\n  --primary:#0f62fe;--primary-dark:#0043ce;--accent:#06b6d4;--gold:#f59e0b;\n  --text:#0f172a;--text-secondary:#475569;--text-muted:#64748b;\n  --shadow:0 1px 3px rgba(0,0,0,.04);--shadow-lg:0 20px 50px rgba(15,98,254,.1);\n  --radius:12px;--radius-lg:20px;\n}\n*{margin:0;padding:0;box-sizing:border-box}\nhtml{scroll-behavior:smooth}\nbody{font-family:'DM Sans',-apple-system,sans-serif;background:var(--bg);color:var(--text);\n  line-height:1.6;font-size:16px;overflow-x:hidden}\n@media(max-width:768px){\n  .header{padding:12px 20px}\n  .nav-links{display:none}\n  .hero,.section{padding-left:24px;padding-right:24px}\n  .hero{padding-top:100px}\n  .cta-section{padding:48px 24px;margin:24px}\n}\n\n/* ── Header ── */\n.header{\n  position:fixed;top:0;left:0;right:0;z-index:100;\n  background:rgba(250,251,252,.95);backdrop-filter:blur(20px);\n  border-bottom:1px solid var(--border);padding:16px 32px;\n  display:flex;align-items:center;justify-content:space-between;\n}\n.logo{font-family:'Outfit',sans-serif;font-weight:800;font-size:20px;color:var(--primary)}\n.logo span{color:var(--accent)}\n.nav-links{display:flex;gap:28px}\n.nav-links a{color:var(--text-secondary);text-decoration:none;font-size:14px;font-weight:500}\n.nav-links a:hover{color:var(--primary)}\n\n/* ── Hero ── */\n.hero{\n  min-height:100vh;display:flex;flex-direction:column;justify-content:center;\n  padding:120px 48px 80px;max-width:1100px;margin:0 auto;\n  position:relative;\n}\n.hero::before{content:'';position:absolute;top:0;right:0;width:50%;height:100%;\n  background:radial-gradient(ellipse at 80% 20%,rgba(15,98,254,.06) 0%,transparent 60%);\n  pointer-events:none;}\n.hero-badge{\n  display:inline-flex;align-items:center;gap:8px;padding:8px 16px;\n  background:linear-gradient(135deg,rgba(15,98,254,.08),rgba(6,182,212,.08));\n  border:1px solid rgba(15,98,254,.15);border-radius:100px;\n  font-size:13px;font-weight:600;color:var(--primary);margin-bottom:28px;\n}\n.hero h1{font-family:'Outfit',sans-serif;font-weight:800;font-size:clamp(40px,6vw,64px);\n  line-height:1.15;letter-spacing:-.03em;color:var(--text);margin-bottom:24px}\n.hero h1 .gradient{background:linear-gradient(135deg,var(--primary),var(--accent));\n  -webkit-background-clip:text;-webkit-text-fill-color:transparent}\n.hero-sub{font-size:clamp(18px,2.2vw,22px);color:var(--text-secondary);\n  max-width:640px;line-height:1.7;margin-bottom:40px}\n.hero-stats{display:flex;gap:48px;flex-wrap:wrap}\n.hero-stat{display:flex;flex-direction:column;gap:4px}\n.hero-stat-num{font-family:'Outfit',sans-serif;font-weight:800;font-size:32px;color:var(--primary)}\n.hero-stat-label{font-size:13px;color:var(--text-muted);font-weight:500}\n\n/* ── Section ── */\nsection{padding:80px 48px;max-width:1100px;margin:0 auto}\n.section-label{\n  font-size:12px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;\n  color:var(--primary);margin-bottom:16px;\n}\n.section-title{font-family:'Outfit',sans-serif;font-weight:700;font-size:clamp(28px,4vw,40px);\n  color:var(--text);margin-bottom:24px;letter-spacing:-.02em}\n.section-desc{font-size:17px;color:var(--text-secondary);max-width:720px;margin-bottom:40px;line-height:1.75}\n\n/* ── Value Cards ── */\n.value-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}\n@media(max-width:900px){.value-grid{grid-template-columns:1fr}}\n.value-card{\n  background:var(--card);border-radius:var(--radius-lg);padding:32px;\n  border:1px solid var(--border);box-shadow:var(--shadow);\n  transition:transform .25s,box-shadow .25s;\n}\n.value-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg)}\n.value-card-icon{\n  width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;\n  font-size:24px;margin-bottom:20px;\n}\n.value-card.v1 .value-card-icon{background:rgba(15,98,254,.1);color:var(--primary)}\n.value-card.v2 .value-card-icon{background:rgba(124,58,237,.1);color:#7c3aed}\n.value-card.v3 .value-card-icon{background:rgba(6,182,212,.1);color:var(--accent)}\n.value-card-title{font-family:'Outfit',sans-serif;font-weight:700;font-size:18px;margin-bottom:12px;color:var(--text)}\n.value-card-desc{font-size:15px;color:var(--text-secondary);line-height:1.7}\n.value-card-highlight{font-size:13px;font-weight:600;color:var(--primary);margin-top:16px}\n\n/* ── Problem ── */\n.problem-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center}\n@media(max-width:768px){.problem-grid{grid-template-columns:1fr}}\n.problem-box{\n  background:linear-gradient(135deg,rgba(239,68,68,.06),rgba(239,68,68,.02));\n  border:1px solid rgba(239,68,68,.15);border-radius:var(--radius-lg);\n  padding:28px;margin-bottom:16px;\n}\n.problem-box h4{font-size:15px;font-weight:700;color:#dc2626;margin-bottom:8px}\n.problem-box p{font-size:14px;color:var(--text-secondary);line-height:1.65}\n.solution-box{\n  background:linear-gradient(135deg,rgba(6,182,212,.08),rgba(15,98,254,.06));\n  border:1px solid rgba(6,182,212,.25);border-radius:var(--radius-lg);\n  padding:28px;\n}\n.solution-box h4{font-size:15px;font-weight:700;color:var(--accent);margin-bottom:8px}\n.solution-box p{font-size:14px;color:var(--text-secondary);line-height:1.65}\n\n/* ── Business Model ── */\n.bt-model{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}\n@media(max-width:900px){.bt-model{grid-template-columns:1fr}}\n.bt-card{\n  background:var(--card);border-radius:var(--radius-lg);padding:32px;\n  border:1px solid var(--border);position:relative;overflow:hidden;\n}\n.bt-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--primary),var(--accent))}\n.bt-card.tier2::before{background:linear-gradient(90deg,#7c3aed,var(--primary))}\n.bt-card.tier3::before{background:linear-gradient(90deg,var(--gold),#f59e0b)}\n.bt-tier{font-size:11px;font-weight:700;letter-spacing:.12em;color:var(--text-muted);margin-bottom:8px}\n.bt-name{font-family:'Outfit',sans-serif;font-weight:700;font-size:20px;color:var(--text);margin-bottom:8px}\n.bt-price{font-size:24px;font-weight:900;color:var(--primary);margin-bottom:20px}\n.bt-features{list-style:none}\n.bt-features li{padding:12px 0;border-bottom:1px solid var(--border);font-size:14px;color:var(--text-secondary);\n  display:flex;align-items:center;gap:10px}\n.bt-features li:last-child{border-bottom:none}\n.bt-features li::before{content:'✓';color:var(--accent);font-weight:700;font-size:16px}\n\n/* ── Roadmap ── */\n.roadmap{position:relative;padding-left:32px}\n.roadmap::before{content:'';position:absolute;left:7px;top:0;bottom:0;width:2px;background:linear-gradient(180deg,var(--primary),var(--accent))}\n.roadmap-item{position:relative;padding-bottom:40px}\n.roadmap-item:last-child{padding-bottom:0}\n.roadmap-dot{position:absolute;left:-32px;top:4px;width:16px;height:16px;border-radius:50%;\n  background:var(--card);border:3px solid var(--primary);box-shadow:0 0 0 4px rgba(15,98,254,.15)}\n.roadmap-item.done .roadmap-dot{background:var(--primary)}\n.roadmap-time{font-size:12px;font-weight:700;color:var(--primary);margin-bottom:8px}\n.roadmap-title{font-family:'Outfit',sans-serif;font-weight:700;font-size:18px;margin-bottom:8px;color:var(--text)}\n.roadmap-desc{font-size:14px;color:var(--text-secondary);line-height:1.65}\n\n/* ── Market ── */\n.market-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}\n@media(max-width:768px){.market-cards{grid-template-columns:1fr}}\n.market-card{\n  background:var(--card);border-radius:var(--radius);padding:28px;\n  border:1px solid var(--border);text-align:center;\n}\n.market-card-num{font-family:'Outfit',sans-serif;font-weight:800;font-size:36px;color:var(--primary);margin-bottom:8px}\n.market-card-num.gold{color:var(--gold)}\n.market-card-num.green{color:var(--accent)}\n.market-card-label{font-size:14px;color:var(--text-secondary);line-height:1.5}\n\n/* ── Competition ── */\n.comp-table{width:100%;border-collapse:collapse;background:var(--card);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}\n.comp-table th{background:var(--primary);color:#fff;padding:16px 20px;text-align:left;font-size:13px;font-weight:600}\n.comp-table td{padding:16px 20px;border-bottom:1px solid var(--border);font-size:14px;color:var(--text-secondary)}\n.comp-table tr:last-child td{border-bottom:none}\n.comp-table tr.us{background:rgba(15,98,254,.04)}\n.comp-table .us-badge{background:var(--primary);color:#fff;padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;\n  display:inline-block;margin-left:8px}\n.comp-table .check{color:var(--accent);font-weight:700}\n.comp-table .dash{color:var(--text-muted)}\n\n/* ── Traction ── */\n.traction-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px}\n.traction-card{background:var(--card);border-radius:var(--radius-lg);padding:32px;border:1px solid var(--border)}\n.traction-card h4{font-family:'Outfit',sans-serif;font-size:18px;margin-bottom:16px;color:var(--text)}\n.traction-card ul{list-style:none}\n.traction-card li{padding:10px 0;border-bottom:1px solid var(--border);font-size:15px;color:var(--text-secondary);\n  display:flex;align-items:flex-start;gap:12px}\n.traction-card li:last-child{border-bottom:none}\n.traction-card li::before{content:'→';color:var(--accent);font-weight:700}\n\n/* ── CTA ── */\n.cta-section{\n  background:linear-gradient(135deg,var(--primary),#0043ce);\n  border-radius:var(--radius-lg);padding:64px 48px;text-align:center;\n  margin:32px 48px 64px;max-width:1100px;margin-left:auto;margin-right:auto;\n}\n.cta-section h2{font-family:'Outfit',sans-serif;font-weight:800;font-size:32px;color:#fff;margin-bottom:16px}\n.cta-section p{font-size:17px;color:rgba(255,255,255,.9);margin-bottom:32px;max-width:560px;margin-left:auto;margin-right:auto}\n.cta-section .contact{font-size:18px;font-weight:600;color:#fff}\n\n/* ── Footer ── */\n.footer{padding:32px 48px;max-width:1100px;margin:0 auto;border-top:1px solid var(--border);\n  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}\n.footer-text{font-size:13px;color:var(--text-muted)}\n.footer-text strong{color:var(--text-secondary)}\n</style>\n</head>\n<body>\n\n<header class=\"header\">\n  <div class=\"logo\">UAS<span>-</span>AIOS</div>\n  <nav class=\"nav-links\">\n    <a href=\"#value\">核心价值</a>\n    <a href=\"#problem\">问题与方案</a>\n    <a href=\"#business\">商业模式</a>\n    <a href=\"#market\">市场机会</a>\n    <a href=\"#roadmap\">产品路线</a>\n    <a href=\"#invest\">投资亮点</a>\n  </nav>\n</header>\n\n<main>\n  <!-- Hero ───────────────────────────────────────── -->\n  <section class=\"hero\">\n    <div class=\"hero-badge\">📊 商业计划书 · 机密 · 2026</div>\n    <h1>AI 操作系统<br><span class=\"gradient\">UAS-AIOS</span></h1>\n    <p class=\"hero-sub\">让每个人都能驾驭所有专业系统的全部智能。我们正在构建下一代 AI 基础设施——将 AI 能力抽象为统一协议，使个人 AI 能够调度任意专业系统完成任意任务。</p>\n    <div style=\"display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:40px\">\n      <span style=\"padding:8px 16px;background:rgba(15,98,254,.08);border-radius:8px;font-size:14px;font-weight:600;color:var(--primary)\">U 个人AI</span>\n      <span style=\"color:var(--text-muted);font-size:18px\">×</span>\n      <span style=\"padding:8px 16px;background:rgba(124,58,237,.08);border-radius:8px;font-size:14px;font-weight:600;color:#7c3aed\">A Agent网络</span>\n      <span style=\"color:var(--text-muted);font-size:18px\">×</span>\n      <span style=\"padding:8px 16px;background:rgba(6,182,212,.08);border-radius:8px;font-size:14px;font-weight:600;color:var(--accent)\">S 专业系统</span>\n      <span style=\"color:var(--text-muted);font-size:18px\">=</span>\n      <span style=\"padding:8px 16px;background:linear-gradient(135deg,var(--primary),var(--accent));border-radius:8px;font-size:14px;font-weight:700;color:#fff\">AI 操作系统</span>\n    </div>\n    <div class=\"hero-stats\" style=\"margin-top:0\">\n      <div class=\"hero-stat\">\n        <span class=\"hero-stat-num\">$85亿</span>\n        <span class=\"hero-stat-label\">2026年 AI Agent 市场规模</span>\n      </div>\n      <div class=\"hero-stat\">\n        <span class=\"hero-stat-num\">4倍</span>\n        <span class=\"hero-stat-label\">2030年预计增长（$350亿）</span>\n      </div>\n      <div class=\"hero-stat\">\n        <span class=\"hero-stat-num\">57%</span>\n        <span class=\"hero-stat-label\">企业已部署 AI Agent</span>\n      </div>\n    </div>\n  </section>\n\n  <!-- 核心价值 ───────────────────────────────────── -->\n  <section id=\"value\">\n    <div class=\"section-label\">核心价值</div>\n    <h2 class=\"section-title\">三大差异化，构建不可替代护城河</h2>\n    <p class=\"section-desc\">UAS-AIOS 不是又一个 AI 聊天工具，而是 AI 交互范式的操作系统化。我们填补了市场空白。</p>\n    <div class=\"value-grid\">\n      <div class=\"value-card v1\">\n        <div class=\"value-card-icon\">🔐</div>\n        <h3 class=\"value-card-title\">懂「这个用户」</h3>\n        <p class=\"value-card-desc\">跨应用持久化个人 AI 模型（Soul Protocol）。一次配置，终身记忆。用户说「帮我看看 Q1 销售」——系统自动注入：用户是数据分析师、偏好 Python、正在做董事会汇报——无需重复解释。</p>\n        <div class=\"value-card-highlight\">vs ChatGPT：无记忆 · vs Notion AI：无跨应用</div>\n      </div>\n      <div class=\"value-card v2\">\n        <div class=\"value-card-icon\">🤖</div>\n        <h3 class=\"value-card-title\">多 Agent 协作</h3>\n        <p class=\"value-card-desc\">基于 Google A2A 协议（50+ 厂商支持）的专家 Agent 网络。主编排 Agent 自动分解任务、路由专家、并行执行、结果合成。用户说「准备明天会议」——3 分钟自动完成：调研 + 数据 + PPT。</p>\n        <div class=\"value-card-highlight\">vs 单点 AI：能执行多步复杂任务</div>\n      </div>\n      <div class=\"value-card v3\">\n        <div class=\"value-card-icon\">📚</div>\n        <h3 class=\"value-card-title\">知识驱动执行</h3>\n        <p class=\"value-card-desc\">ASUI 知识层让 AI 理解业务语义。每个系统配 SYSTEM.md：业务规则、操作规范、月末锁账期禁止修改——AI 自动遵守。100% 可审计，满足金融/医疗合规。</p>\n        <div class=\"value-card-highlight\">vs 纯 API 调用：懂业务语义</div>\n      </div>\n    </div>\n  </section>\n\n  <!-- 问题与方案 ─────────────────────────────────── -->\n  <section id=\"problem\">\n    <div class=\"section-label\">问题与方案</div>\n    <h2 class=\"section-title\">解决 AI 碎片化的根本矛盾</h2>\n    <div class=\"problem-grid\">\n      <div>\n        <h3 style=\"font-size:18px;margin-bottom:20px;color:var(--text)\">当前痛点</h3>\n        <div class=\"problem-box\">\n          <h4>个人 AI 懂我，但不懂专业系统</h4>\n          <p>ChatGPT 对话流畅，但无法操作企业 CRM、ERP、数据平台。</p>\n        </div>\n        <div class=\"problem-box\">\n          <h4>专业 AI 懂系统，但不理解我</h4>\n          <p>每次都要重新解释需求、偏好、上下文。体验割裂。</p>\n        </div>\n        <div class=\"problem-box\">\n          <h4>AI 决策不可审计</h4>\n          <p>73% 企业报告「可靠性问题」是最大障碍。合规刚需。</p>\n        </div>\n      </div>\n      <div>\n        <h3 style=\"font-size:18px;margin-bottom:20px;color:var(--text)\">UAS 方案</h3>\n        <div class=\"solution-box\">\n          <h4>U 层：个人 AI 持久化</h4>\n          <p>Soul Protocol 用户身份 + Cecil 三层记忆。跨应用「这个用户」理解。</p>\n        </div>\n        <div class=\"solution-box\">\n          <h4>A 层：Agent 协作网络</h4>\n          <p>A2A 协议驱动多专家并行。主编排 + 代码/数据/文档/业务 Agent。</p>\n        </div>\n        <div class=\"solution-box\">\n          <h4>S 层：知识驱动执行</h4>\n          <p>MCP 工具 + ASUI 知识文档。AI 理解业务语义，100% 可审计。</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- 商业模式 ─────────────────────────────────── -->\n  <section id=\"business\">\n    <div class=\"section-label\">商业模式</div>\n    <h2 class=\"section-title\">三层收入结构，清晰可扩展</h2>\n    <p class=\"section-desc\">采用「开源引流 + 商业增值」双轨战略，参考扣子、百度飞桨的验证路径。</p>\n    <div class=\"bt-model\">\n      <div class=\"bt-card\">\n        <div class=\"bt-tier\">PERSONAL</div>\n        <div class=\"bt-name\">Your AI</div>\n        <div class=\"bt-price\">$20-50 / 月</div>\n        <ul class=\"bt-features\">\n          <li>跨应用统一 AI 身份</li>\n          <li>持久化记忆</li>\n          <li>主动提醒与目标追踪</li>\n          <li>模型无关</li>\n        </ul>\n      </div>\n      <div class=\"bt-card tier2\">\n        <div class=\"bt-tier\">ENTERPRISE · 核心</div>\n        <div class=\"bt-name\">UAS Enterprise</div>\n        <div class=\"bt-price\">$100K-1M / 年</div>\n        <ul class=\"bt-features\">\n          <li>团队 Soul 管理</li>\n          <li>企业系统全接入（10+ MCP）</li>\n          <li>内部 Agent Marketplace</li>\n          <li>全链路审计（SOC 2）</li>\n          <li>私有化部署</li>\n        </ul>\n      </div>\n      <div class=\"bt-card tier3\">\n        <div class=\"bt-tier\">PLATFORM</div>\n        <div class=\"bt-name\">UAS Protocol</div>\n        <div class=\"bt-price\">抽成 20% + API</div>\n        <ul class=\"bt-features\">\n          <li>Agent 开发 SDK</li>\n          <li>System MCP 适配器库</li>\n          <li>Agent Marketplace（发布销售）</li>\n          <li>UAS 认证体系</li>\n        </ul>\n      </div>\n    </div>\n    <div style=\"margin-top:32px;padding:24px;background:rgba(15,98,254,.04);border-radius:var(--radius);border:1px solid rgba(15,98,254,.15)\">\n      <div style=\"font-size:14px;font-weight:600;color:var(--primary);margin-bottom:8px\">收入目标</div>\n      <div style=\"font-size:15px;color:var(--text-secondary);line-height:1.7\">\n        12 个月：3+ 付费客户，ARR $100K · 24 个月：10+ 企业，ARR $500K · 36 个月：平台化，ARR $1M+\n      </div>\n    </div>\n  </section>\n\n  <!-- 市场机会 ─────────────────────────────────── -->\n  <section id=\"market\">\n    <div class=\"section-label\">市场机会</div>\n    <h2 class=\"section-title\">18-36 个月战略窗口</h2>\n    <div class=\"market-cards\">\n      <div class=\"market-card\">\n        <div class=\"market-card-num\">$85亿</div>\n        <div class=\"market-card-label\">2026 年 AI Agent 市场规模</div>\n      </div>\n      <div class=\"market-card\">\n        <div 