{
  "$schema": "https://asui.dev/schemas/agent_registry.schema.json",
  "version": "v1.0",
  "description": "领域构建评估专业Agent注册表",
  "agent_templates": [
    {
      "id": "domain-analyzer-v1",
      "type": "Analyzer",
      "name": "领域分析Agent",
      "capabilities": [
        "本质提取",
        "矛盾识别",
        "主体发现",
        "差异矩阵构建"
      ],
      "source": "builtin",
      "config": {
        "model": "claude-sonnet-4-6",
        "temperature": 0.7,
        "skills": ["domain_builder.md"]
      }
    },
    {
      "id": "strategy-planner-v1",
      "type": "Planner",
      "name": "策略规划Agent",
      "capabilities": [
        "策略生成",
        "路径优化",
        "风险评估",
        "资源调度"
      ],
      "source": "template",
      "config": {
        "model": "claude-sonnet-4-6",
        "temperature": 0.5
      }
    },
    {
      "id": "orchestrator-v1",
      "type": "Executor",
      "name": "调度编排Agent",
      "capabilities": [
        "任务分解",
        "Agent编排",
        "进度跟踪",
        "异常处理"
      ],
      "source": "builtin",
      "config": {
        "model": "claude-sonnet-4-6",
        "temperature": 0.3,
        "orchestration_mode": "adaptive"
      }
    },
    {
      "id": "evaluator-v1",
      "type": "Evaluator",
      "name": "评估审计Agent",
      "capabilities": [
        "指标计算",
        "偏差检测",
        "一致性校验",
        "合规审查"
      ],
      "source": "builtin",
      "config": {
        "model": "claude-sonnet-4-6",
        "temperature": 0.2
      }
    },
    {
      "id": "evolver-v1",
      "type": "Evolver",
      "name": "演化优化Agent",
      "capabilities": [
        "反馈整合",
        "知识更新",
        "策略迭代",
        "能力扩展"
      ],
      "source": "template",
      "config": {
        "model": "claude-sonnet-4-6",
        "temperature": 0.6
      }
    }
  ],
  "external_connectors": [
    {
      "id": "mcp-github",
      "type": "external",
      "name": "GitHub MCP",
      "capabilities": ["code_analysis", "pr_review"],
      "adapter": "mcp"
    },
    {
      "id": "mcp-filesystem",
      "type": "external",
      "name": "文件系统MCP",
      "capabilities": ["file_ops", "search"],
      "adapter": "mcp"
    },
    {
      "id": "rest-api-custom",
      "type": "external",
      "name": "自定义REST API",
      "capabilities": ["custom_business_logic"],
      "adapter": "rest"
    }
  ],
  "matching_rules": {
    "domain_analysis": ["domain-analyzer-v1"],
    "strategy_planning": ["strategy-planner-v1"],
    "execution": ["orchestrator-v1"],
    "evaluation": ["evaluator-v1"],
    "evolution": ["evolver-v1"],
    "code_related": ["mcp-github"],
    "file_related": ["mcp-filesystem"]
  }
}