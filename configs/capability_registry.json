          "input": {
            "type": "object",
            "properties": {
              "owner_id": { "type": "string" },
              "status": { "type": "string" }
            }
          },
          "output": {
            "type": "object",
            "properties": {
              "items": { "type": "array" }
            }
          },
          "approval_level": "L1",
          "audit_required": true,
          "gates": ["G1"],
          "agent_visible": true
        }
      ]
    },
    {
      "id": "cs.ticket",
      "domain": "ticket",
      "description": "客服工单创建、更新与升级",
      "source_system": "itsm",
      "connector_id": "connector.itsm.sandbox",
      "enabled": true,
      "operations": [
        {
          "name": "create",
