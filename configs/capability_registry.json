      "description": "客户主数据查询与画像",
      "source_system": "crm",
      "connector_id": "connector.crm.sandbox",
      "uas_layer": "S",
      "enabled": true,
      "operations": [
        {
          "name": "get_profile",
          "description": "按 customer_id 获取客户画像与关键字段",
          "input": {
            "type": "object",
            "required": ["customer_id"],
            "properties": {
              "customer_id": { "type": "string" },
              "tenant_id": { "type": "string" }
            }
          },
          "output": {
            "type": "object",
            "required": ["customer_id", "name"],
            "properties": {
              "customer_id": { "type": "string" },
              "name": { "type": "string" },
              "segment": { "type": "string" },
              "evidence": { "type": "array", "items": { "type": "string" } }
            }
          },
          "approval_level": "L1",
          "audit_required": true,
          "gates": ["G1", "G6"],
          "side_effects": [],
          "idempotent": true,
          "agent_visible": true
        },
        {
          "name": "query",
          "description": "按条件检索客户列表（分页）",
          "input": {
            "type": "object",
            "properties": {
              "filter": { "type": "object" },
              "limit": { "type": "integer", "maximum": 100 }
            }
          },
          "output": {
            "type": "object",
            "properties": {
              "items": { "type": "array" },
              "total": { "type": "integer" }
            }
          },
          "approval_level": "L1",
          "audit_required": true,
          "gates": ["G1", "G6"],
          "agent_visible": true
        }
      ]
    },
    {
