          "input": {
            "type": "object",
            "required": ["ticket_id", "reason"],
            "properties": {
              "ticket_id": { "type": "string" },
              "reason": { "type": "string" }
            }
          },
          "output": {
            "type": "object",
            "properties": {
              "escalation_id": { "type": "string" },
              "assigned_to": { "type": "string" }
            }
          },
          "approval_level": "L2",
          "audit_required": true,
          "gates": ["G6"],
          "side_effects": ["event.ticket.escalated"],
          "agent_visible": true
        }
      ]
    },
