          "input": {
            "type": "object",
            "required": ["subject", "customer_id"],
            "properties": {
              "subject": { "type": "string" },
              "customer_id": { "type": "string" },
              "priority": { "type": "string", "enum": ["low", "normal", "high", "urgent"] }
