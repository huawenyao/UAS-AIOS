{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asui.dev/schemas/enterprise_intent.schema.json",
  "title": "EnterpriseIntent",
  "type": "object",
  "required": [
    "intent_id",
    "tenant_id",
    "tier_source",
    "actor",
    "intent_type",
    "goal",
    "status",
    "created_at"
  ],
  "properties": {
    "intent_id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "tier_source": {
      "type": "string",
      "enum": ["DH-L1", "DH-L2", "DH-L3", "external"]
    },
    "actor": { "$ref": "#/$defs/actor" },
    "intent_type": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "maxLength": 2000 },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "escalation_target": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["open", "escalated", "resolved", "cancelled"]
    },
    "parent_intent_id": { "type": "string", "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "linked_evidence_ids": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "planned_capabilities": {
      "type": "array",
      "items": { "type": "string", "pattern": "^cs\\.[a-z]+\\.[a-z_]+$" }
    },
    "executed_capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability", "request_id"],
        "properties": {
          "capability": { "type": "string" },
          "request_id": { "type": "string", "format": "uuid" }
        }
      }
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "required": ["user_id"],
      "properties": {
        "user_id": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "tier": { "type": "string" },
        "delegation_from": { "type": ["string", "null"] }
      }
    }
  }
}
