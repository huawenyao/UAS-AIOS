{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asui.dev/schemas/enterprise_cs_invoke.schema.json",
  "title": "EnterpriseCsInvokeRequest",
  "type": "object",
  "required": [
    "capability",
    "capability_version",
    "tenant_id",
    "actor",
    "idempotency_key",
    "payload"
  ],
  "properties": {
    "capability": {
      "type": "string",
      "pattern": "^cs\\.[a-z]+\\.[a-z_]+$"
    },
    "capability_version": { "type": "string" },
    "tenant_id": { "type": "string" },
    "actor": {
      "type": "object",
      "required": ["user_id"],
      "properties": {
        "user_id": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "tier": { "type": "string" },
        "delegation_from": { "type": ["string", "null"] }
      }
    },
    "idempotency_key": { "type": "string", "format": "uuid" },
    "policy_bundle_id": { "type": "string" },
    "payload": { "type": "object" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
