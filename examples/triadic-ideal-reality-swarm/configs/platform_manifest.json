  },
  "layers": {
    "I": "Intent Layer",
    "K": "Knowledge Substrate",
    "R": "Autonomous Agent Runtime",
    "A": "Agent Fabric",
    "S": "System Mesh",
    "G": "Governance Plane",
    "E": "Evolution Loop",
    "Π": "Protocol Stack"
  },
  "defaults": {
    "subapp_root": "examples",
    "require_governance": true,
    "require_evolution": true,
    "require_audit": true
  }
