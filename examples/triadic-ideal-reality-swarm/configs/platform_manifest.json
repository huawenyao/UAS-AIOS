{
  "$schema": "https://asui.dev/schemas/uas_platform_manifest.schema.json",
  "version": "v1.0",
  "platform": {
    "name": "UAS-Platform",
    "formal_definition": ["I", "K", "R", "A", "S", "G", "E", "Π"],
    "enterprise_agi_definition": "目标驱动 + 知识驱动 + Agent协作 + 系统执行 + 审计治理 + 演化闭环 的平台化统一",
    "technical_base": "ASUI",
