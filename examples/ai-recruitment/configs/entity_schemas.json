{
  "$schema": "https://asui.dev/schemas/entity_schemas.schema.json",
  "version": "v1.0",
  "description": "AI 招聘 UAS App 关键实体结构化管理，与 autonomous_agent runtime 的 task 级状态、审计与事件驱动对齐",
  "entities": {
    "Job": {
      "id_field": "job_id",
      "required": ["job_id", "created_at"],
      "fields": {
        "job_id": { "type": "string", "description": "岗位唯一标识" },
        "raw_jd": { "type": "string", "description": "原始 JD 文本" },
        "parsed_profile": { "type": "object", "description": "解析后的岗位画像" },
        "status": { "type": "string", "enum": ["draft", "open", "paused", "closed"], "default": "open" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "storage": "database/jobs.json"
    },
    "Candidate": {
      "id_field": "candidate_id",
      "required": ["candidate_id", "job_id", "created_at"],
      "fields": {
        "candidate_id": { "type": "string" },
        "job_id": { "type": "string", "description": "关联岗位" },
        "name": { "type": "string" },
        "scores": { "type": "object" },
        "decision": { "type": "string", "enum": ["strong_recommend", "recommend", "borderline", "not_recommend"] },
        "risk_flags": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "basic_info": { "type": "object" },
        "status": { "type": "string", "enum": ["screened", "shortlisted", "interview_scheduled", "interview_completed", "offered", "rejected"], "default": "screened" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "storage": "database/candidates.json"
    },
    "Task": {
      "id_field": "task_id",
      "description": "与 runtime 的 state_isolation: task_level 对齐，每个 Task 为一次可审计的执行单元",
      "required": ["task_id", "type", "status", "created_at"],
      "fields": {
        "task_id": { "type": "string" },
        "type": { "type": "string", "enum": ["screening", "ai_interview", "human_interview", "evaluation_review"], "description": "任务类型" },
        "status": { "type": "string", "enum": ["pending", "running", "completed", "failed", "cancelled"], "default": "pending" },
        "job_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "payload": { "type": "object", "description": "任务输入/上下文" },
        "result": { "type": "object", "description": "任务输出，完成后写入" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "storage": "database/tasks.json"
    },
    "Event": {
      "id_field": "event_id",
      "description": "业务与运行时事件，驱动状态流转与审计",
      "required": ["event_id", "event_type", "occurred_at"],
      "fields": {
        "event_id": { "type": "string" },
        "event_type": { "type": "string", "description": "见 event_policy 中定义" },
        "task_id": { "type": "string" },
        "job_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "payload": { "type": "object" },
        "occurred_at": { "type": "string", "format": "date-time" }
      },
      "storage": "database/events.json"
    },
    "Notification": {
      "id_field": "notification_id",
      "required": ["notification_id", "event_id", "created_at"],
      "fields": {
        "notification_id": { "type": "string" },
        "event_id": { "type": "string" },
        "channel": { "type": "string", "enum": ["in_app", "email", "webhook"], "default": "in_app" },
        "recipient_role": { "type": "string", "description": "hr_recruiter | hiring_manager | candidate" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "sent", "failed"], "default": "pending" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "storage": "database/notifications.json"
    },
    "Evaluation": {
      "id_field": "evaluation_id",
      "required": ["evaluation_id", "candidate_id", "created_at"],
      "fields": {
        "evaluation_id": { "type": "string" },
        "task_id": { "type": "string", "description": "关联的面试/评估任务" },
        "candidate_id": { "type": "string" },
        "job_id": { "type": "string" },
        "scope": { "type": "string", "enum": ["screening", "ai_interview", "human_interview", "combined"], "default": "ai_interview" },
        "dimensions": { "type": "object", "description": "专业能力/沟通表达/逻辑思维/文化契合等得分" },
        "summary": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "storage": "database/evaluations.json"
    }
  }
}
